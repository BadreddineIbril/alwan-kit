---
import VisualPrimary from "@/assets/icons/shape-1.svg";
import VisualSecondary from "@/assets/icons/shape-2.svg";
import VisualTertiary from "@/assets/icons/shape-3.svg";
---

<section ui-section="not-found">
  <div class="wrapper">
    <div class="announcement">
      <i class="hgi hgi-stroke hgi-sad-dizzy"></i> 404
    </div>
    <h1 class="heading">
      You seem <span>lost.</span>
    </h1>
    <a
      href="/"
      ui-slot="button"
      data-variant="primary"
      data-mode="filled"
      data-size="lg">
      <i class="hgi hgi-stroke hgi-arrow-left-01"></i>
      Back Home
    </a>
    <VisualPrimary data-visual="primary" />
    <VisualSecondary data-visual="secondary" />
    <VisualTertiary data-visual="tertiary" />
  </div>
</section>

<style>
  [ui-section="not-found"] {
    display: flex;
    place-content: center;
    padding-block-start: calc(var(--spacing-64) * 2);

    .wrapper {
      width: 600px;
      text-align: center;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: var(--spacing-24);
      position: relative;

      .announcement {
        font: var(--font-body-sm);
        border-radius: var(--radius-rounded);
        padding: var(--spacing-2) var(--spacing-8);
        background-color: var(--color-surface-container-lowest);
        box-shadow: var(--shadow-lg);
        display: flex;
        align-items: center;
        gap: var(--spacing-4);

        & > i {
          color: var(--color-primary);
        }
      }

      .heading {
        text-transform: capitalize;
        font: var(--font-display-lg);

        span {
          color: var(--color-primary);
        }
      }

      .description {
        font: var(--font-body-lg);
        color: var(--color-on-surface-variant);
      }

      [data-visual] {
        position: absolute;
        width: var(--spacing-64);
        height: var(--spacing-64);
        filter: blur(2px) opacity(0.5);

        &[data-visual="primary"] {
          inset-block-start: -40%;
        }

        &[data-visual="secondary"] {
          rotate: -15deg;
          inset-block-start: 50%;
          inset-inline-start: -20%;
        }

        &[data-visual="tertiary"] {
          inset-block-start: 50%;
          inset-inline-end: -20%;
        }
      }
    }

    @media (max-width: 769px) {
      padding-block-start: var(--spacing-64);

      .wrapper {
        width: 100%;

        .heading {
          font: var(--font-headline-lg);
        }

        [data-visual] {
          width: var(--spacing-48);
          height: var(--spacing-48);

          &[data-visual="secondary"] {
            inset-block-start: -10%;
            inset-inline-start: 10%;
          }

          &[data-visual="tertiary"] {
            inset-block-start: -10%;
            inset-inline-end: 10%;
          }
        }
      }
    }
  }
</style>
