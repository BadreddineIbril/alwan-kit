---
import VisualPrimary from "@/assets/icons/shape-1.svg";
import VisualSecondary from "@/assets/icons/shape-2.svg";
import VisualTertiary from "@/assets/icons/shape-3.svg";
---

<section ui-section="hero">
  <div class="wrapper">
    <div class="announcement">
      <i class="hgi hgi-stroke hgi-idea-01"></i> Open Source · WCAG Accessible · Pure
      CSS · <a href="/colors" ui-slot="link-button" data-variant="primary"
        >Try it now!</a
      >
    </div>
    <h1 class="heading">
      One <span>color</span>
      <br /> A whole system
    </h1>
    <p class="description">
      Pick a color, choose a harmony, and get a complete, WCAG accessible color
      palette for your app or design system.
    </p>
    <div class="actions">
      <a
        href="/colors"
        ui-slot="button"
        data-variant="primary"
        data-mode="filled"
        data-size="lg">
        My Palette
      </a>
      <a
        href="/explore"
        ui-slot="button"
        data-variant="neutral"
        data-mode="filled"
        data-size="lg">
        Browse Palettes
      </a>
    </div>
    <VisualPrimary data-visual="primary" />
    <VisualSecondary data-visual="secondary" />
    <VisualTertiary data-visual="tertiary" />
  </div>
</section>

<style>
  [ui-section="hero"] {
    display: flex;
    place-content: center;
    padding-block-start: calc(var(--spacing-64) * 2);

    .wrapper {
      width: 600px;
      text-align: center;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: var(--spacing-24);
      position: relative;

      .announcement {
        font: var(--font-body-sm);
        border-radius: var(--radius-rounded);
        padding: var(--spacing-4) var(--spacing-8);
        background-color: var(--color-surface-container-lowest);
        box-shadow: var(--shadow-lg);
        display: flex;
        align-items: center;
        gap: var(--spacing-4);
        width: max-content;

        & > i {
          color: var(--color-primary);
        }
      }

      .heading {
        text-transform: capitalize;
        font: var(--font-display-lg);

        span {
          color: var(--color-primary);
        }
      }

      .description {
        font: var(--font-body-lg);
        color: var(--color-on-surface-variant);
      }

      .actions {
        display: flex;
        gap: var(--spacing-12);

        & > [ui-slot="button"] {
          min-width: 150px;
        }
      }

      [data-visual] {
        position: absolute;
        width: var(--spacing-64);
        height: var(--spacing-64);
        filter: blur(2px) opacity(0.5);

        &[data-visual="primary"] {
          inset-block-start: -30%;
        }

        &[data-visual="secondary"] {
          rotate: -15deg;
          inset-block-start: 50%;
          inset-inline-start: -20%;
        }

        &[data-visual="tertiary"] {
          inset-block-start: 50%;
          inset-inline-end: -20%;
        }
      }
    }

    @media (max-width: 769px) {
      padding-block-start: var(--spacing-64);

      .wrapper {
        width: 100%;

        .heading {
          font: var(--font-headline-lg);
        }

        [data-visual] {
          width: var(--spacing-48);
          height: var(--spacing-48);

          &[data-visual="primary"] {
            inset-block-start: -20%;
          }

          &[data-visual="secondary"] {
            inset-block-start: 10%;
            inset-inline-start: 0%;
          }

          &[data-visual="tertiary"] {
            inset-block-start: 10%;
            inset-inline-end: 0%;
          }
        }
      }
    }
  }
</style>
